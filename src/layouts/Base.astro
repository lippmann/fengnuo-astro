---
interface Props {
  title: string;
  description?: string;
}
const { title, description = '冯诺 — 译者、写作者、业余开发者' } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;700;900&family=IBM+Plex+Mono:ital,wght@0,200;0,300;0,400;1,300&display=swap">
  <link rel="icon" href="/favicon.ico">
</head>
<body>
  <slot />
</body>
</html>

<!-- Theme init: run before paint to avoid flash -->
<script is:inline>
(function () {
  var saved = localStorage.getItem('site-theme') || 'light';
  document.documentElement.setAttribute('data-theme', saved);
}());
</script>

<style is:global>
  @import '/src/styles/global.css';
</style>
