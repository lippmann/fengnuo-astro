---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const books = (await getCollection('books')).sort((a, b) => a.data.order - b.data.order);
const total = books.length;
const years = books.map(b => b.data.year).sort();
const yearRange = `${years[0]} — ${years[years.length - 1]}`;

---

<Base title="译的书 · 冯诺" description="冯诺翻译作品列表">

<nav>
  <a class="nav-home" href="/">冯诺</a>
  <ul class="nav-links">
    <li><a href="/translations" class="here">译的书</a></li>
    <li><a href="/writing">写的文</a></li>
    <li><a href="/projects">编的程</a></li>
    <li><a href="/tweets">碎的念</a></li>
  </ul>
  <button class="theme-toggle" id="themeBtn" onclick="toggleTheme()" aria-label="切换主题">
    <svg id="iconSun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <circle cx="12" cy="12" r="4"/>
      <line x1="12" y1="2" x2="12" y2="4"/>
      <line x1="12" y1="20" x2="12" y2="22"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="2" y1="12" x2="4" y2="12"/>
      <line x1="20" y1="12" x2="22" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg id="iconMoon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</nav>

<section class="hero">
  <div class="hero-bg" aria-hidden="true">译</div>
  <div class="hero-content">
    <p class="hero-eyebrow">Works · Translation</p>
    <h1 class="hero-title">译的书</h1>
    <p class="hero-count">{total} Volumes &nbsp;·&nbsp; {yearRange}</p>
    <div class="hero-rule"></div>
    <p class="hero-desc">在两种语言之间寻找对等，<br>在两个世界之间架设桥梁。</p>
  </div>
  <div class="hero-scroll">
    <span class="hero-scroll-line"></span>
    Scroll
  </div>
</section>

<section class="books">
  {books.map((book, i) => (
    <a class="book-entry" href={book.data.douban} target="_blank" rel="noopener">
      <div class="book-cover-col">
        <img
          class="book-cover-img"
          src={book.data.cover}
          alt={book.data.title}
          loading="lazy"
        />
      </div>
      <div class="book-info-col">
        <div class="book-num">{String(i + 1).padStart(2, '0')} / {String(total).padStart(2, '0')}</div>
        <h2 class="book-title">{book.data.title}</h2>
        <p class="book-original">{book.data.original}</p>
        <p class="book-author-line"><span>作者</span> {book.data.author}</p>
        <div class="book-divider"></div>
        <p class="book-desc">{book.body}</p>
        <div class="book-footer">
          <span class="book-year">
            {book.data.year}{book.data.publisher ? ` · ${book.data.publisher}` : ''}
          </span>
          <span class="book-link">豆瓣</span>
        </div>
      </div>
    </a>
  ))}
</section>

<footer>
  <a class="foot-back" href="/">← 返回主页</a>
  <span class="foot-copy">© 2026 冯诺</span>
</footer>

</Base>

<style>
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 52px;
  height: 56px;
  background: var(--nav-gradient);
  transition: background .25s;
}
.nav-home {
  font-family: 'Noto Serif SC', serif;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: .02em;
  opacity: .7;
  transition: opacity .2s;
}
.nav-home:hover { opacity: 1; }
.nav-links {
  display: flex;
  gap: 28px;
  list-style: none;
}
.nav-links a {
  font-size: 10px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--dim);
  transition: color .2s;
}
.nav-links a:hover { color: var(--paper); }
.nav-links a.here { color: var(--gold); }
.theme-toggle {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--dim);
  display: flex;
  align-items: center;
  padding: 4px;
  transition: color .2s;
}
.theme-toggle:hover { color: var(--paper); }
.theme-toggle svg { width: 15px; height: 15px; }

.hero {
  min-height: 100vh;
  display: flex;
  align-items: flex-end;
  padding: 0 52px 88px;
  position: relative;
  overflow: hidden;
  border-bottom: 1px solid var(--rule);
}
.hero-bg {
  position: absolute;
  right: -4vw; top: 50%;
  transform: translateY(-50%);
  font-family: 'Noto Serif SC', serif;
  font-size: 55vw;
  font-weight: 900;
  line-height: 1;
  color: transparent;
  -webkit-text-stroke: 1px var(--hero-stroke);
  user-select: none;
  pointer-events: none;
  letter-spacing: -.04em;
}
.hero-content {
  position: relative;
  z-index: 2;
  max-width: 600px;
}
.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 10px;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 300;
  margin-bottom: 28px;
}
.hero-eyebrow::before {
  content: '';
  display: block;
  width: 28px; height: 1px;
  background: var(--gold);
  opacity: .6;
}
.hero-title {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(48px, 7vw, 88px);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: .04em;
  color: var(--paper);
  margin-bottom: 20px;
}
.hero-count {
  font-size: 10px;
  letter-spacing: .2em;
  color: var(--dim);
  font-weight: 300;
  margin-bottom: 36px;
}
.hero-rule {
  width: 40px; height: 1px;
  background: var(--gold);
  opacity: .35;
  margin-bottom: 20px;
}
.hero-desc {
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 2;
  color: var(--paper-faint);
  max-width: 380px;
}
.hero-scroll {
  position: absolute;
  bottom: 40px; right: 52px;
  z-index: 2;
  writing-mode: vertical-rl;
  font-size: 9px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 10px;
}
.hero-scroll-line {
  width: 1px; height: 40px;
  background: linear-gradient(to bottom, var(--muted), transparent);
}

.books { padding: 0 0 120px; }

.book-entry {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 540px;
  border-bottom: 1px solid var(--rule);
  position: relative;
  overflow: hidden;
}
.book-entry:nth-child(even) { direction: rtl; }
.book-entry:nth-child(even) > * { direction: ltr; }

.book-cover-col {
  position: relative;
  overflow: hidden;
  background: var(--surface);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64px 80px;
  transition: background .25s;
}
.book-cover-col::after {
  content: '';
  position: absolute; inset: 0;
  background: var(--cover-overlay);
  pointer-events: none;
}
.book-cover-img {
  position: relative;
  z-index: 1;
  max-width: 220px;
  width: 100%;
  aspect-ratio: 2/3;
  object-fit: cover;
  display: block;
  box-shadow: var(--shadow-sm);
  border-radius: 2px;
  transition: transform .5s cubic-bezier(.22,1,.36,1), box-shadow .5s ease;
}
.book-entry:hover .book-cover-img {
  transform: translateY(-12px) scale(1.02);
  box-shadow: var(--shadow-hover);
}
.book-info-col {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 64px 72px;
  border-left: 1px solid var(--rule);
}
.book-entry:nth-child(even) .book-info-col {
  border-left: none;
  border-right: 1px solid var(--rule);
}
.book-num {
  font-size: 9px;
  letter-spacing: .2em;
  color: var(--gold-d);
  margin-bottom: 24px;
  font-weight: 300;
}
.book-title {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: .02em;
  color: var(--paper);
  margin-bottom: 6px;
  transition: color .2s;
}
.book-entry:hover .book-title { color: var(--gold); }
.book-original {
  font-style: italic;
  font-size: 12px;
  font-weight: 200;
  color: var(--dim);
  letter-spacing: .04em;
  margin-bottom: 8px;
}
.book-author-line {
  font-size: 11px;
  color: var(--dim);
  font-weight: 300;
  letter-spacing: .06em;
  margin-bottom: 32px;
}
.book-author-line span { color: var(--author-span); }
.book-divider {
  width: 32px; height: 1px;
  background: rgba(201,169,110,.25);
  margin-bottom: 28px;
}
.book-desc {
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 2;
  color: var(--paper-dim);
  max-width: 400px;
  margin-bottom: 36px;
}
.book-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24px;
  border-top: 1px solid var(--rule);
}
.book-year {
  font-size: 10px;
  letter-spacing: .16em;
  color: var(--dim);
  font-weight: 300;
}
.book-link {
  font-size: 10px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--gold-d);
  transition: color .2s;
  display: flex;
  align-items: center;
  gap: 8px;
}
.book-link:hover { color: var(--gold); }
.book-link::after {
  content: '→';
  transition: transform .2s;
}
.book-entry:hover .book-link::after { transform: translateX(4px); }

footer {
  border-top: 1px solid var(--rule);
  padding: 28px 52px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.foot-back {
  font-size: 11px;
  letter-spacing: .1em;
  color: var(--dim);
  transition: color .2s;
}
.foot-back:hover { color: var(--paper); }
.foot-copy {
  font-size: 9px;
  letter-spacing: .12em;
  color: var(--muted);
}

@media (max-width: 860px) {
  .book-entry, .book-entry:nth-child(even) {
    grid-template-columns: 1fr;
    direction: ltr;
  }
  .book-cover-col { padding: 48px; min-height: 360px; }
  .book-info-col {
    padding: 40px 32px;
    border-left: none;
    border-top: 1px solid var(--rule);
  }
  .book-entry:nth-child(even) .book-info-col {
    border-right: none;
    border-top: 1px solid var(--rule);
  }
  nav { padding: 0 24px; }
  .hero { padding: 0 24px 72px; }
}
</style>

<script is:inline>
function updateIcon(isDark) {
  document.getElementById('iconSun').style.display  = isDark ? 'block' : 'none';
  document.getElementById('iconMoon').style.display = isDark ? 'none'  : 'block';
}
function toggleTheme() {
  var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  var next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('site-theme', next);
  updateIcon(next === 'dark');
}
(function () {
  var saved = localStorage.getItem('site-theme') || 'light';
  updateIcon(saved === 'dark');
}());
</script>
