---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const articles = await getCollection('writing');
  articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return paginate(articles, { pageSize: 20 });
}

const { page } = Astro.props as any;
const total = page.total;

function formatDateShort(d: Date) {
  return `${d.getFullYear()}.${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')}`;
}
---

<Base title="写的文 · 冯诺" description="冯诺非虚构写作作品合集">

<nav>
  <a class="nav-home" href="/">冯诺</a>
  <ul class="nav-links">
    <li><a href="/translations">译的书</a></li>
    <li><a href="/writing" class="here">写的文</a></li>
    <li><a href="/projects">编的程</a></li>
    <li><a href="/tweets">碎的念</a></li>
  </ul>
  <button class="theme-toggle" id="themeBtn" onclick="toggleTheme()" aria-label="切换主题">
    <svg id="iconSun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <circle cx="12" cy="12" r="4"/>
      <line x1="12" y1="2" x2="12" y2="4"/>
      <line x1="12" y1="20" x2="12" y2="22"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="2" y1="12" x2="4" y2="12"/>
      <line x1="20" y1="12" x2="22" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg id="iconMoon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</nav>

<section class="hero">
  <div class="hero-bg" aria-hidden="true">文</div>
  <div class="hero-content">
    <p class="hero-eyebrow">Works · Writing</p>
    <h1 class="hero-title">写的文</h1>
    <p class="hero-count">{total} Articles &nbsp;·&nbsp; Page {page.currentPage} / {page.lastPage}</p>
    <div class="hero-rule"></div>
    <p class="hero-desc">为各家媒体撰写的非虚构文章，<br>科普、财经、社会与人文。</p>
  </div>
  <div class="hero-scroll">
    <span class="hero-scroll-line"></span>
    Scroll
  </div>
</section>

<section class="writing">
  <div class="article-list">
    {page.data.map((art: any) => (
      <a class="article-entry" href={`/writing/${art.slug}`}>
        <span class="article-date">{formatDateShort(art.data.date)}</span>
        <div class="article-body">
          <h2 class="article-title">{art.data.title}</h2>
          {art.data.description && (
            <p class="article-desc">{art.data.description}</p>
          )}
        </div>
        <span class="article-media">{art.data.media}</span>
      </a>
    ))}
  </div>

  <nav class="pagination" aria-label="分页">
    {page.url.prev ? (
      <a class="page-btn" href={page.url.prev}>← 上一页</a>
    ) : (
      <span class="page-btn disabled">← 上一页</span>
    )}
    <span class="page-info">{page.currentPage} / {page.lastPage}</span>
    {page.url.next ? (
      <a class="page-btn" href={page.url.next}>下一页 →</a>
    ) : (
      <span class="page-btn disabled">下一页 →</span>
    )}
  </nav>
</section>

<footer class="site-footer">
  <span>© 冯诺</span>
</footer>

</Base>

<style>
/* ── Nav ── */
nav {
  position: sticky; top: 0; z-index: 50;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 48px; height: 60px;
  background: var(--nav-gradient);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--rule);
}
.nav-home {
  font-family: 'Noto Serif SC', serif;
  font-size: 15px; font-weight: 700;
  color: var(--paper); letter-spacing: .02em;
}
.nav-links {
  display: flex; gap: 32px; list-style: none;
}
.nav-links a {
  font-family: 'Noto Serif SC', serif;
  font-size: 12px; font-weight: 400; letter-spacing: .18em;
  text-transform: uppercase; color: var(--muted);
  transition: color .2s;
}
.nav-links a:hover, .nav-links a.here { color: var(--gold); }
.theme-toggle {
  background: none; border: none; cursor: pointer;
  color: var(--muted); padding: 6px; display: flex;
  transition: color .2s;
}
.theme-toggle:hover { color: var(--paper); }
.theme-toggle svg { width: 17px; height: 17px; }

/* ── Hero ── */
.hero {
  position: relative; overflow: hidden;
  min-height: 52vh;
  display: flex; align-items: center;
  padding: 72px 48px 64px;
  border-bottom: 1px solid var(--rule);
}
.hero-bg {
  position: absolute; right: 60px; top: 50%; transform: translateY(-50%);
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(180px, 28vw, 320px);
  font-weight: 900; line-height: 1;
  color: transparent;
  -webkit-text-stroke: 1px var(--hero-stroke);
  pointer-events: none; user-select: none;
}
.hero-content { position: relative; z-index: 1; }
.hero-eyebrow {
  font-family: 'Cormorant SC', serif;
  font-size: 12px; font-weight: 400; letter-spacing: .22em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 12px; display: flex; align-items: center; gap: 12px;
}
.hero-eyebrow::before {
  content: ''; display: block; width: 28px; height: 1px;
  background: var(--gold); opacity: .6;
}
.hero-title {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(52px, 9vw, 88px);
  font-weight: 900; line-height: 1;
  color: var(--paper); letter-spacing: .02em; margin-bottom: 8px;
}
.hero-count {
  font-family: 'Cormorant SC', serif;
  font-size: 12px; font-weight: 400; letter-spacing: .18em;
  color: var(--muted); margin-bottom: 20px;
}
.hero-rule { width: 36px; height: 1px; background: var(--gold); opacity: .4; margin-bottom: 16px; }
.hero-desc {
  font-family: 'Libre Caslon Text', 'Noto Serif SC', serif;
  font-size: 14px; font-weight: 400; line-height: 2.0;
  color: var(--dim);
}
.hero-scroll {
  position: absolute; bottom: 28px; right: 48px;
  font-family: 'Cormorant SC', serif;
  font-size: 11px; font-weight: 400; letter-spacing: .16em;
  color: var(--muted); display: flex; align-items: center; gap: 10px;
}
.hero-scroll-line {
  display: block; width: 24px; height: 1px; background: var(--muted); opacity: .5;
}

/* ── Writing section ── */
.writing {
  max-width: 900px; margin: 0 auto;
  padding: 48px 48px 80px;
}

/* ── Article list ── */
.article-list { margin-bottom: 48px; }
.article-entry {
  display: grid;
  grid-template-columns: 88px 1fr auto;
  gap: 0 20px;
  align-items: start;
  padding: 18px 0;
  border-bottom: 1px solid var(--rule);
  text-decoration: none;
}
.article-entry:hover .article-title { color: var(--gold); }
.article-date {
  font-family: 'Cormorant SC', serif;
  font-size: 11px; font-weight: 400; letter-spacing: .1em;
  color: var(--muted); white-space: nowrap; padding-top: 3px;
  text-align: right;
}
.article-body { min-width: 0; }
.article-title {
  font-family: 'Noto Serif SC', serif;
  font-size: 16px; font-weight: 500; line-height: 1.5;
  color: var(--paper); margin-bottom: 5px;
  transition: color .2s;
}
.article-desc {
  font-family: 'Libre Caslon Text', 'Noto Serif SC', serif;
  font-size: 13px; font-weight: 400; line-height: 1.8;
  color: var(--dim);
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden;
}
.article-media {
  font-family: 'Cormorant SC', serif;
  font-size: 10px; font-weight: 400; letter-spacing: .12em;
  color: var(--muted); white-space: nowrap;
  border: 1px solid var(--rule); border-radius: 2px;
  padding: 2px 7px; align-self: start; margin-top: 3px;
}

/* ── Pagination ── */
.pagination {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 32px;
  border-top: 1px solid var(--rule);
}
.page-btn {
  font-family: 'Cormorant SC', serif;
  font-size: 12px; font-weight: 400; letter-spacing: .14em;
  color: var(--gold); text-decoration: none;
  transition: opacity .2s;
}
.page-btn:hover { opacity: .7; }
.page-btn.disabled { color: var(--muted); pointer-events: none; }
.page-info {
  font-family: 'Cormorant SC', serif;
  font-size: 11px; font-weight: 400; letter-spacing: .14em;
  color: var(--muted);
}

/* ── Footer ── */
.site-footer {
  padding: 28px 48px;
  border-top: 1px solid var(--rule);
  font-size: 11px; letter-spacing: .1em; color: var(--muted);
}

@media (max-width: 640px) {
  nav { padding: 0 20px; }
  .hero { padding: 48px 20px 40px; }
  .writing { padding: 32px 20px 60px; }
  .hero-bg { right: 20px; }
  .site-footer { padding: 24px 20px; }
  .article-entry { grid-template-columns: 72px 1fr; }
  .article-media { display: none; }
}
</style>

<script is:inline>
function updateIcon(isDark) {
  document.getElementById('iconSun').style.display  = isDark ? 'block' : 'none';
  document.getElementById('iconMoon').style.display = isDark ? 'none'  : 'block';
}
function toggleTheme() {
  var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  var next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('site-theme', next);
  updateIcon(next === 'dark');
}
(function () {
  var saved = localStorage.getItem('site-theme') || 'light';
  updateIcon(saved === 'dark');
}());
</script>
