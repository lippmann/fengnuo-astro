        </svg>
        <span>X / Twitter</span>
      </a>
      <a class="social-link" href="https://github.com/lippmann" target="_blank" rel="noopener">
        <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <span>GitHub</span>
      </a>
      <a class="social-link" href="https://www.goodreads.com/user/show/6966773-rui" target="_blank" rel="noopener">
        <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.43 23.995c-3.608-.208-6.274-2.077-6.448-5.078.695.007 1.375-.013 2.07-.006.224 1.342 1.065 2.43 2.415 3.031 1.888.844 4.786.603 6.285-.87.948-.933 1.378-2.21 1.378-3.44v-1.245c-1.743 1.964-4.3 2.352-6.42 1.426-2.908-1.25-4.793-4.103-4.793-7.143-.013-3.95 2.55-7.206 6.128-8.16 3.885-1.03 7.945 1.032 8.895 5.093.123.516.193 1.04.193 1.574l.013 8.3c.01 4.57-3.645 6.42-9.716 6.518zm.316-8.025c2.256-.033 4.395-1.988 4.394-4.895-.001-2.895-1.83-5.044-4.394-5.087-2.323-.037-4.745 1.77-4.745 5.087-.001 3.05 2.137 5.01 4.745 4.895z"/>
        </svg>
        <span>Goodreads</span>
      </a>
      <a class="social-link" href="https://bookmeter.com/users/994960" target="_blank" rel="noopener">
        <svg class="social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
