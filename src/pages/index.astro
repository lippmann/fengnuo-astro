</Base>

<style>
.theme-toggle {
  position: fixed;
  bottom: 28px;
  right: 28px;
  z-index: 99;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--dim);
  display: flex;
  align-items: center;
  padding: 4px;
  transition: color .2s;
}
.theme-toggle:hover { color: var(--paper); }
.theme-toggle svg { width: 15px; height: 15px; }

.hero {
  padding: 0 0 0 60px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  align-items: stretch;
  height: 100vh;
  border-bottom: 1px solid var(--rule);
}
.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 0;
}
.hero-eyebrow {
  font-size: 10px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--dim);
  font-weight: 300;
  margin-bottom: 32px;
}
.hero-name {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(72px, 10vw, 120px);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -.02em;
  color: var(--paper);
  margin-bottom: 0;
}
.hero-name-dot {
  color: var(--gold);
}
.hero-tagline {
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 1.9;
  color: var(--dim);
  max-width: 420px;
  margin-top: 36px;
  padding-top: 36px;
  border-top: 1px solid var(--rule);
}
.hero-tagline p {
  margin: 0 0 14px;
}
.hero-tagline p:last-child { margin-bottom: 0; }
.hero-roles {
  display: flex;
  gap: 20px;
  margin-top: 28px;
}
.hero-role {
  font-size: 10px;
  font-weight: 300;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--muted);
}
.hero-role + .hero-role::before {
  content: '·';
  margin-right: 20px;
  color: var(--gold);
  opacity: .5;
}
.hero-social {
  display: flex;
  gap: 20px;
  margin-top: 40px;
}
.hero-social a {
  font-size: 10px;
  font-weight: 300;
  letter-spacing: .1em;
  color: var(--dim);
  text-transform: uppercase;
  transition: color .15s;
}
.hero-social a:hover { color: var(--gold); }

.hero-right {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 1px;
  background: var(--rule);
  border-left: 1px solid var(--rule);
}
.work-card {
  background: var(--bg);
  padding: 36px 32px;
  border-radius: 2px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  cursor: pointer;
  transition: background .2s, transform .2s;
  border: 1px solid var(--rule);
  position: relative;
  overflow: hidden;
}
.work-card:hover {
  background: var(--surface);
  transform: none;
}

/* ── SVG illustrations ── */
.card-svg {
  position: absolute;
  left: 50%;
  top: 55%;
  transform: translate(-50%, -50%);
  opacity: .15;
  color: var(--gold);
  pointer-events: none;
  transition: opacity .5s ease, transform .6s cubic-bezier(.22,1,.36,1);
}
.work-card:hover .card-svg {
  opacity: .3;
  transform: translate(-50%, -54%) scale(1.04);
}

/* 译的书 — 两册分开合拢 */
@keyframes spread-l {
  0%, 100% { transform: translateX(0); }
  45%, 55% { transform: translateX(-12px); }
}
@keyframes spread-r {
  0%, 100% { transform: translateX(0); }
  45%, 55% { transform: translateX(12px); }
}
.work-card:hover .svg-books .book-l { animation: spread-l 3.2s cubic-bezier(.45,0,.55,1) infinite; }
.work-card:hover .svg-books .book-r { animation: spread-r 3.2s cubic-bezier(.45,0,.55,1) infinite; }

/* 写的文 — 钢笔尖脉冲 + 末行书写 */
@keyframes pen-pulse {
  0%, 100% { r: 2.5; opacity: 1; }
  50%       { r: 4;   opacity: .5; }
}
.svg-pen .write-line {
  stroke-dasharray: 34;
  stroke-dashoffset: 34;
  transition: stroke-dashoffset 1s .15s ease;
}
.work-card:hover .svg-pen .write-line { stroke-dashoffset: 0; }
.work-card:hover .svg-pen .pen-tip   { animation: pen-pulse 2.4s ease-in-out infinite; }

/* 编的程 — 括号滑入 + 光标闪烁 */
@keyframes cursor-blink {
  0%, 49% { opacity: 1; }
  50%, 100% { opacity: 0; }
}
.svg-code .bracket-l { transform: translateX(8px);  transition: transform .5s cubic-bezier(.22,1,.36,1); }
.svg-code .bracket-r { transform: translateX(-8px); transition: transform .5s cubic-bezier(.22,1,.36,1); }
.work-card:hover .svg-code .bracket-l,
.work-card:hover .svg-code .bracket-r { transform: translateX(0); }
.work-card:hover .svg-code .cursor    { animation: cursor-blink 1s step-end infinite; }

/* 碎的念 — 气泡漂浮 */
@keyframes float-a { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
@keyframes float-b { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-4px)} }
@keyframes float-c { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-2px)} }
.work-card:hover .svg-fragments .frag-a { animation: float-a 3s ease-in-out infinite; }
.work-card:hover .svg-fragments .frag-b { animation: float-b 3s .4s ease-in-out infinite; }
.work-card:hover .svg-fragments .frag-c { animation: float-c 3s .8s ease-in-out infinite; }
.work-card:hover .svg-fragments .frag-d { animation: float-a 3s 1.2s ease-in-out infinite; }
.work-num {
  font-size: 9px;
  font-weight: 300;
  letter-spacing: .14em;
  color: var(--gold);
}
.work-title {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(22px, 2.5vw, 28px);
  font-weight: 700;
  color: var(--paper);
  letter-spacing: .01em;
  flex: 1;
}
.work-arrow {
  font-size: 13px;
  color: var(--gold);
  opacity: .6;
}

footer {
  padding: 28px 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid var(--rule);
}
.footer-text {
  font-size: 10px;
  font-weight: 300;
  letter-spacing: .14em;
  color: var(--muted);
}

@media (max-width: 900px) {
  .hero {
    grid-template-columns: 1fr;
    height: auto;
    padding: 60px 24px 0;
  }
  .hero-left { padding: 0 0 48px; }
  .hero-right {
    border-left: none;
    border-top: 1px solid var(--rule);
    margin: 0 -24px;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
  }
  nav { padding: 0 24px; }
  footer { padding: 24px; }
}
</style>

<script is:inline>
function updateIcon(isDark) {
  document.getElementById('iconSun').style.display  = isDark ? 'block' : 'none';
  document.getElementById('iconMoon').style.display = isDark ? 'none'  : 'block';
}
function toggleTheme() {
  var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  var next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('site-theme', next);
  updateIcon(next === 'dark');
}
(function () {
  var saved = localStorage.getItem('site-theme') || 'light';
  updateIcon(saved === 'dark');
}());
</script>
