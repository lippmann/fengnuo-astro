---
import Base from '../layouts/Base.astro';
---

<Base title="冯诺" description="冯诺 — 译者、写作者、业余开发者">

<nav>
  <div class="nav-logo">冯诺<span>·</span></div>
  <ul class="nav-links">
    <li><a href="/books">译的书</a></li>
    <li><a href="/writing">写的文</a></li>
    <li><a href="/projects">编的程</a></li>
    <li><a href="/tweets">碎的念</a></li>
  </ul>
  <button class="theme-toggle" id="themeBtn" onclick="toggleTheme()" aria-label="切换主题">
    <svg id="iconSun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <circle cx="12" cy="12" r="4"/>
      <line x1="12" y1="2" x2="12" y2="4"/>
      <line x1="12" y1="20" x2="12" y2="22"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="2" y1="12" x2="4" y2="12"/>
      <line x1="20" y1="12" x2="22" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg id="iconMoon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</nav>

<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">译者 · 写作者 · 业余开发者</p>
    <h1 class="hero-name">冯诺<span class="hero-name-dot"></span></h1>
    <p class="hero-tagline">在语言之间穿行。翻译人文社科，写随笔与书评，也在深夜 vibe coding。</p>
    <div class="hero-roles">
      <span class="hero-role">Translator</span>
      <span class="hero-role">Writer</span>
      <span class="hero-role">Developer</span>
    </div>
    <div class="hero-social">
      <a href="https://www.douban.com/people/L.Revolution/" target="_blank" rel="noopener">豆瓣</a>
      <a href="https://x.com/Surudo1892" target="_blank" rel="noopener">X / Twitter</a>
      <a href="https://github.com/lippmann" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
  <div class="hero-right">
    <a class="work-card" href="/books">
      <div class="work-num">01 · Translator</div>
      <div class="work-title">译的书</div>
      <div class="work-arrow">→</div>
    </a>
    <a class="work-card" href="/writing">
      <div class="work-num">02 · Writer</div>
      <div class="work-title">写的文</div>
      <div class="work-arrow">→</div>
    </a>
    <a class="work-card" href="/projects">
      <div class="work-num">03 · Developer</div>
      <div class="work-title">编的程</div>
      <div class="work-arrow">→</div>
    </a>
    <a class="work-card" href="/tweets">
      <div class="work-num">04 · Says</div>
      <div class="work-title">碎的念</div>
      <div class="work-arrow">→</div>
    </a>
  </div>
</section>

<footer>
  <span class="footer-text">© 2026 冯诺</span>
  <span class="footer-text">Translator · Writer · Developer</span>
</footer>

</Base>

<style>
nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 60px;
  height: 64px;
  border-bottom: 1px solid var(--rule);
}
.nav-logo {
  font-family: 'Noto Serif SC', serif;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: .04em;
  color: var(--paper);
}
.nav-logo span { color: var(--gold); }
.nav-links {
  display: flex;
  gap: 32px;
  list-style: none;
}
.nav-links a {
  font-size: 11px;
  letter-spacing: .12em;
  color: var(--dim);
  transition: color .15s;
}
.nav-links a:hover { color: var(--paper); }
.theme-toggle {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--dim);
  display: flex;
  align-items: center;
  padding: 4px;
  transition: color .2s;
}
.theme-toggle:hover { color: var(--paper); }
.theme-toggle svg { width: 15px; height: 15px; }

.hero {
  padding: 0 60px;
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 48px;
  align-items: stretch;
  height: calc(100vh - 64px);
  border-bottom: 1px solid var(--rule);
}
.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 0;
}
.hero-eyebrow {
  font-size: 10px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--dim);
  font-weight: 300;
  margin-bottom: 32px;
}
.hero-name {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(72px, 10vw, 120px);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -.02em;
  color: var(--paper);
  margin-bottom: 0;
}
.hero-name-dot {
  display: inline-block;
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--gold);
  margin-left: 4px;
  vertical-align: super;
}
.hero-tagline {
  font-family: 'Noto Serif SC', serif;
  font-size: 15px;
  font-weight: 300;
  line-height: 2;
  color: var(--dim);
  max-width: 420px;
  margin-top: 36px;
  padding-top: 36px;
  border-top: 1px solid var(--rule);
}
.hero-roles {
  display: flex;
  gap: 20px;
  margin-top: 28px;
}
.hero-role {
  font-size: 10px;
  font-weight: 300;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--muted);
}
.hero-role + .hero-role::before {
  content: '·';
  margin-right: 20px;
  color: var(--gold);
  opacity: .5;
}
.hero-social {
  display: flex;
  gap: 20px;
  margin-top: 40px;
}
.hero-social a {
  font-size: 10px;
  font-weight: 300;
  letter-spacing: .1em;
  color: var(--dim);
  text-transform: uppercase;
  transition: color .15s;
}
.hero-social a:hover { color: var(--gold); }

.hero-right {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 1px;
  background: var(--rule);
  border-left: 1px solid var(--rule);
}
.work-card {
  background: var(--bg);
  padding: 36px 32px;
  border-radius: 2px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  cursor: pointer;
  transition: background .2s, transform .2s;
  border: 1px solid var(--rule);
}
.work-card:hover {
  background: var(--surface);
  transform: none;
}
.work-num {
  font-size: 9px;
  font-weight: 300;
  letter-spacing: .14em;
  color: var(--gold);
}
.work-title {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(22px, 2.5vw, 28px);
  font-weight: 700;
  color: var(--paper);
  letter-spacing: .01em;
  flex: 1;
}
.work-arrow {
  font-size: 13px;
  color: var(--gold);
  opacity: .6;
}

footer {
  padding: 28px 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid var(--rule);
}
.footer-text {
  font-size: 10px;
  font-weight: 300;
  letter-spacing: .14em;
  color: var(--muted);
}

@media (max-width: 900px) {
  .hero {
    grid-template-columns: 1fr;
    height: auto;
    padding: 60px 24px 0;
  }
  .hero-left { padding: 0 0 48px; }
  .hero-right {
    border-left: none;
    border-top: 1px solid var(--rule);
    margin: 0 -24px;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
  }
  nav { padding: 0 24px; }
  footer { padding: 24px; }
}
</style>

<script is:inline>
function updateIcon(isDark) {
  document.getElementById('iconSun').style.display  = isDark ? 'block' : 'none';
  document.getElementById('iconMoon').style.display = isDark ? 'none'  : 'block';
}
function toggleTheme() {
  var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  var next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('site-theme', next);
  updateIcon(next === 'dark');
}
(function () {
  var saved = localStorage.getItem('site-theme') || 'light';
  updateIcon(saved === 'dark');
}());
</script>
