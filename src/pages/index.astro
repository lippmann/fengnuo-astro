        <rect x="8" y="8" width="114" height="74" rx="6" stroke-width="1" opacity=".4"/>
        <circle cx="22" cy="22" r="3.5" stroke-width="1" opacity=".5"/>
        <circle cx="34" cy="22" r="3.5" stroke-width="1" opacity=".5"/>
