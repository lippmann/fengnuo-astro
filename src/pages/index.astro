        </g>
        <g class="book-r">
          <rect x="80" y="8" width="54" height="74" rx="2" stroke-width="1.2"/>
          <line x1="93"  y1="8"  x2="93"  y2="82" stroke-width=".7" opacity=".3"/>
          <line x1="80"  y1="10" x2="80"  y2="80" stroke-width="3"  stroke-linecap="round" opacity=".07"/>
          <line x1="98" y1="26" x2="126" y2="26" stroke-width="2"   stroke-linecap="round"/>
          <line x1="98" y1="35" x2="122" y2="35" stroke-width="1.2" stroke-linecap="round" opacity=".55"/>
          <line x1="98" y1="44" x2="112" y2="44" stroke-width="1"   stroke-linecap="round" opacity=".38"/>
          <line x1="98" y1="64" x2="120" y2="64" stroke-width=".8"  stroke-linecap="round" opacity=".3"/>
        </g>
      </svg>
    </a>
    <a class="work-card" href="/writing">
      <div class="work-num">02 · Writer</div>
      <div class="work-title">写的文</div>
      <div class="work-arrow">→</div>
      <svg class="card-svg svg-pen" width="220" height="152" viewBox="0 0 130 90" fill="none" stroke="currentColor" aria-hidden="true">
        <line x1="8"  y1="16" x2="122" y2="16" stroke-width="1"   stroke-linecap="round" opacity=".5"/>
        <line x1="8"  y1="31" x2="122" y2="31" stroke-width="1"   stroke-linecap="round" opacity=".5"/>
        <line x1="8"  y1="46" x2="122" y2="46" stroke-width="1"   stroke-linecap="round" opacity=".5"/>
        <line x1="8"  y1="61" x2="88"  y2="61" stroke-width="1"   stroke-linecap="round" opacity=".5"/>
