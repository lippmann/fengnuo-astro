---
import Base from '../../layouts/Base.astro';
import feedData from '../../data/feed.json';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const feed = feedData as any[];
  return paginate(feed, { pageSize: 20 });
}

const { page } = Astro.props as any;

function formatDate(iso: string) {
  const [y, m, d] = iso.split('-');
  return `${y} · ${m} · ${d}`;
}

function filterImages(images: string[]) {
  return images.filter(img => !img.includes('new_menu') && !img.includes('/icon/'));
}

function parseWeread(text: string): { annotation: string; highlight: string; bookLine: string } {
  const lines = text.split('\n');
  const bookLine = lines[0] || '';
  const rest = lines.slice(1).join('\n').trim();
  let highlight = '';
  let annotation = '';
  if (rest.includes('💬')) {
    const noteIdx = rest.indexOf('💬');
    highlight = rest.slice(0, noteIdx).trim();
    annotation = rest.slice(noteIdx + '💬'.length).trim();
  } else {
    highlight = rest.replace(/^\[.*?\]\n+/, '').trim();
  }
  return { annotation, highlight, bookLine };
}

function parseTwitter(text: string): { comment: string; rtAuthor: string; rtHandle: string; rtText: string } | null {
  // New format: JSON string with explicit fields
  if (text.trim().startsWith('{')) {
    try {
      const parsed = JSON.parse(text);
      if (parsed.rtAuthor && parsed.rtText) return parsed;
    } catch {}
  }
  // Legacy fallback: plain text with "author (@handle) rtText" pattern
  const m = text.match(/^([\s\S]*?)([^\n(]+?)\s+\(@([A-Za-z0-9_]{1,50})\)\s+([\s\S]+)$/);
  if (!m) return null;
  const rtText = m[4].trim().replace(/\s+—\s+https?:\/\/\S+$/, '').trim();
  if (!rtText || rtText.length < 3) return null;
  return { comment: m[1].trim(), rtAuthor: m[2].trim(), rtHandle: m[3].trim(), rtText };
}
---

<Base title="碎的念 · 冯诺" description="冯诺的碎片记录 — 豆瓣 · X / Twitter">

<nav>
  <a class="nav-home" href="/">冯诺</a>
  <ul class="nav-links">
    <li><a href="/translations">译的书</a></li>
    <li><a href="/writing">写的文</a></li>
    <li><a href="/projects">编的程</a></li>
    <li><a href="/tweets" class="here">碎的念</a></li>
  </ul>
  <button class="theme-toggle" id="themeBtn" onclick="toggleTheme()" aria-label="切换主题">
    <svg id="iconSun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <circle cx="12" cy="12" r="4"/>
      <line x1="12" y1="2" x2="12" y2="4"/>
      <line x1="12" y1="20" x2="12" y2="22"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="2" y1="12" x2="4" y2="12"/>
      <line x1="20" y1="12" x2="22" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg id="iconMoon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</nav>

<main>
  <header class="page-header">
    <p class="page-eyebrow">Daily Murmurs</p>
    <h1 class="page-title">碎的念</h1>
    <p class="page-count">{page.total} 条记录 &nbsp;·&nbsp; Page {page.currentPage} / {page.lastPage}</p>
  </header>

  <div class="filter-bar">
    <button class="filter-btn active" data-filter="all">全部</button>
    <button class="filter-btn" data-filter="twitter">推特博文</button>
    <button class="filter-btn" data-filter="douban">豆瓣广播</button>
    <button class="filter-btn" data-filter="weread">读书笔记</button>
  </div>

  <div class="feed">
    {page.data.map((item: any) => {
      const imgs = filterImages(item.images || []);
      const isWeread = item.platform === 'weread';
      const isTwitter = item.platform === 'twitter';
      const wr = isWeread ? parseWeread(item.text) : null;
      const tw = isTwitter ? parseTwitter(item.text) : null;
      return (
        <div class="card" data-platform={item.platform}>
          <div class="card-header">
            <div class="card-left">
              <span class={`badge badge-${item.platform}`}>
                {item.platform === 'twitter' ? '推特博文' : isWeread ? '读书笔记' : '豆瓣广播'}
              </span>
              {!isWeread && (
                <a class="card-source" href={item.url} target="_blank" rel="noopener">查看原文</a>
              )}
            </div>
            <span class="card-date">{formatDate(item.date)}</span>
          </div>

          {isWeread && wr ? (
            <div class="wr-body">
              {wr.annotation && <p class="wr-annotation">{wr.annotation}</p>}
              {wr.highlight && (
                <blockquote class="wr-highlight">{wr.highlight}</blockquote>
              )}
              <p class="wr-bookline">{wr.bookLine}</p>
            </div>
          ) : isTwitter && tw ? (
            <div class="tw-body">
              {tw.comment && <p class="tw-comment">{tw.comment}</p>}
              <blockquote class="tw-rt">
                <p class="tw-rt-author">
                  <span class="tw-rt-name">{tw.rtAuthor}</span>
                  <span class="tw-rt-handle">@{tw.rtHandle}</span>
                </p>
                <p class="tw-rt-text">{tw.rtText}</p>
                {imgs.length > 0 && (
                  <div class="card-imgs">
                    {imgs.slice(0, 4).map((img: string) => (
                      <img src={img} loading="lazy" alt="" />
                    ))}
                  </div>
                )}
              </blockquote>
            </div>
          ) : (
            <p class="card-text">{item.text}</p>
          )}

          {(!isTwitter || !tw) && imgs.length > 0 && (
            <div class="card-imgs">
              {imgs.slice(0, 4).map((img: string) => (
                <img src={img} loading="lazy" alt="" />
              ))}
            </div>
          )}
        </div>
      );
    })}
  </div>

  <nav class="pagination" aria-label="分页">
    {page.url.prev ? (
      <a class="page-btn" href={page.url.prev}>← 上一页</a>
    ) : (
      <span class="page-btn disabled">← 上一页</span>
    )}
    <span class="page-info">{page.currentPage} / {page.lastPage}</span>
    {page.url.next ? (
      <a class="page-btn" href={page.url.next}>下一页 →</a>
    ) : (
      <span class="page-btn disabled">下一页 →</span>
    )}
  </nav>
</main>

<footer>
  <a class="foot-back" href="/">← 返回主页</a>
  <span class="foot-copy">© 2026 冯诺</span>
</footer>

</Base>

<style>
nav {
  position: sticky;
  top: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 52px;
  height: 56px;
  background: var(--nav-gradient);
  border-bottom: 1px solid var(--rule);
  transition: background .25s;
}
.nav-home {
  font-family: 'Noto Serif SC', serif;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: .02em;
  opacity: .7;
  transition: opacity .2s;
}
.nav-home:hover { opacity: 1; }
.nav-links {
  display: flex;
  gap: 28px;
  list-style: none;
}
.nav-links a {
  font-family: 'Noto Serif SC', serif;
  font-size: 10px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--dim);
  transition: color .2s;
}
.nav-links a:hover { color: var(--paper); }
.nav-links a.here { color: var(--gold); }
.theme-toggle {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--dim);
  display: flex;
  align-items: center;
  padding: 4px;
  transition: color .2s;
}
.theme-toggle:hover { color: var(--paper); }
.theme-toggle svg { width: 15px; height: 15px; }

main {
  max-width: 680px;
  margin: 0 auto;
  padding: 72px 24px 100px;
}

.page-header {
  margin-bottom: 56px;
  padding-bottom: 24px;
}
.page-eyebrow {
  font-size: 10px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 300;
  margin-bottom: 16px;
}
.page-title {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(36px, 6vw, 56px);
  font-weight: 900;
  color: var(--paper);
  letter-spacing: .02em;
  margin-bottom: 12px;
}
.page-count {
  font-size: 10px;
  letter-spacing: .16em;
  color: var(--muted);
  font-weight: 300;
}

.filter-bar {
  display: flex;
  gap: 8px;
  margin-bottom: 28px;
  flex-wrap: wrap;
}
.filter-btn {
  font-family: 'Cormorant SC', serif;
  font-size: 10px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--muted);
  background: none;
  border: 1px solid var(--rule);
  border-radius: 8px;
  padding: 5px 12px;
  cursor: pointer;
  transition: color .15s, border-color .15s, background .15s;
}
.filter-btn:hover {
  color: var(--dim);
  border-color: var(--dim);
}
.filter-btn.active {
  color: var(--gold);
  border-color: var(--gold);
  background: color-mix(in srgb, var(--gold) 6%, transparent);
}

/* ── Feed ── */
.feed {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* ── Card ── */
.card {
  background: var(--surface);
  border: 1px solid var(--rule);
  border-radius: 8px;
  padding: 20px 22px;
  box-shadow: var(--shadow-sm);
  transition: transform .25s cubic-bezier(.2,.8,.2,1), box-shadow .25s cubic-bezier(.2,.8,.2,1);
  will-change: transform;
}
.card:hover {
  transform: translateY(-6px) scale(1.004);
  box-shadow: var(--shadow-hover);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}
.card-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* ── Platform badges ── */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 9px;
  border-radius: 10px;
  border: 1px solid var(--rule);
  background: var(--bg);
  font-family: 'Cormorant SC', serif;
  font-size: 9px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--muted);
  transition: border-color .2s;
}
.badge-weread {
  border-color: rgba(22,119,255,.3);
  color: #1677ff;
  background: rgba(22,119,255,.05);
}
.badge-douban {
  border-color: rgba(7,167,97,.3);
  color: #07a761;
  background: rgba(7,167,97,.05);
}
.badge-twitter {
  border-color: rgba(10,16,14,.2);
  color: var(--paper);
  background: color-mix(in srgb, var(--paper) 5%, transparent);
}
[data-theme="dark"] .badge-twitter {
  border-color: rgba(232,240,238,.15);
}

.card-source {
  font-family: 'Cormorant SC', serif;
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--gold);
  opacity: 0;
  transition: opacity .2s;
}
.card:hover .card-source { opacity: 1; }

.card-date {
  font-family: 'Libre Baskerville', serif;
  font-size: 9px;
  color: var(--muted);
  letter-spacing: .04em;
}

/* ── Plain text ── */
.card-text {
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 1.95;
  color: var(--dim);
  white-space: pre-wrap;
}

/* ── WeRead ── */
.wr-body { display: flex; flex-direction: column; gap: 8px; }
.wr-annotation {
  font-family: 'Noto Serif SC', serif;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.9;
  color: var(--dim);
  margin: 0;
}
.wr-highlight {
  margin: 0;
  padding: 4px 0 4px 44px;
  border: none;
  background: none;
  position: relative;
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 2;
  color: var(--dim);
}
.wr-highlight::before {
  content: '\201C';
  position: absolute;
  left: 0;
  top: -10px;
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: 56px;
  line-height: 1;
  color: #1677ff;
  opacity: .6;
  font-weight: 700;
}
.wr-bookline {
  margin: 0;
  font-family: 'Libre Baskerville', serif;
  font-size: 10px;
  letter-spacing: .06em;
  color: var(--muted);
  text-align: right;
}

/* ── Twitter repost ── */
.tw-body { display: flex; flex-direction: column; gap: 10px; }
.tw-comment {
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 1.95;
  color: var(--dim);
  margin: 0;
  white-space: pre-wrap;
}
.tw-rt {
  margin: 0;
  padding: 12px 14px;
  border: 1px solid var(--rule);
  border-radius: 5px;
  background: color-mix(in srgb, var(--bg) 60%, transparent);
}
.tw-rt-author {
  display: flex;
  align-items: baseline;
  gap: 6px;
  margin: 0 0 6px;
}
.tw-rt-name {
  font-family: 'Noto Serif SC', serif;
  font-size: 13px;
  font-weight: 500;
  color: var(--paper);
}
.tw-rt-handle {
  font-family: 'Libre Baskerville', serif;
  font-size: 11px;
  color: var(--gold);
  letter-spacing: .03em;
}
.tw-rt-text {
  font-family: 'Noto Serif SC', serif;
  font-size: 13px;
  font-weight: 300;
  line-height: 1.85;
  color: var(--dim);
  margin: 0;
  white-space: pre-wrap;
}
.tw-rt .card-imgs {
  margin-top: 10px;
  margin-bottom: 0;
}

/* ── Images ── */
.card-imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 14px;
}
.card-imgs img {
  width: 92px;
  height: 92px;
  object-fit: cover;
  border-radius: 4px;
}

/* ── Pagination ── */
.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 32px;
  margin-top: 32px;
  border-top: 1px solid var(--rule);
}
.page-btn {
  font-family: 'Cormorant SC', serif;
  font-size: 12px;
  font-weight: 400;
  letter-spacing: .14em;
  color: var(--gold);
  text-decoration: none;
  transition: opacity .2s;
}
.page-btn:hover { opacity: .7; }
.page-btn.disabled { color: var(--muted); pointer-events: none; }
.page-info {
  font-family: 'Cormorant SC', serif;
  font-size: 11px;
  font-weight: 400;
  letter-spacing: .14em;
  color: var(--muted);
}

footer {
  border-top: 1px solid var(--rule);
  padding: 24px 52px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.foot-back {
  font-size: 11px;
  letter-spacing: .1em;
  color: var(--dim);
  transition: color .2s;
}
.foot-back:hover { color: var(--paper); }
.foot-copy {
  font-size: 9px;
  letter-spacing: .12em;
  color: var(--muted);
}

@media (max-width: 640px) {
  nav { padding: 0 20px; }
  main { padding: 48px 20px 80px; }
  footer { padding: 20px; }
}
</style>

<script is:inline>
function updateIcon(isDark) {
  document.getElementById('iconSun').style.display  = isDark ? 'block' : 'none';
  document.getElementById('iconMoon').style.display = isDark ? 'none'  : 'block';
}
function toggleTheme() {
  var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  var next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('site-theme', next);
  updateIcon(next === 'dark');
}
(function () {
  var saved = localStorage.getItem('site-theme') || 'light';
  updateIcon(saved === 'dark');
}());

(function () {
  var btns = document.querySelectorAll('.filter-btn');
  var entries = document.querySelectorAll('.card');
  btns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var filter = btn.getAttribute('data-filter');
      btns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      entries.forEach(function (entry) {
        var show = filter === 'all' || entry.getAttribute('data-platform') === filter;
        entry.style.display = show ? '' : 'none';
      });
    });
  });
}());
</script>
