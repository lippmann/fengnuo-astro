---
import Base from '../../layouts/Base.astro';
import feedData from '../../data/feed.json';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const feed = feedData as any[];
  return paginate(feed, { pageSize: 20 });
}

const { page } = Astro.props as any;

function formatDate(iso: string) {
  const [y, m, d] = iso.split('-');
  return `${y} · ${m} · ${d}`;
}

function filterImages(images: string[]) {
  return images.filter(img => !img.includes('new_menu') && !img.includes('/icon/'));
}

function proxyImg(url: string) {
  return url;
}

// Parse weread text into structured parts.
// text format (bookmark):  "《书名》 — 作者\n[章节]\n\n摘录"
// text format (review):    "《书名》 — 作者\n\n摘录\n💬 笔记"  (abstract may be empty)
function parseWeread(text: string): { annotation: string; highlight: string; bookLine: string } {
  const lines = text.split('\n');
  const bookLine = lines[0] || '';  // always "《书名》 — 作者"

  // Collect remaining lines (skip empty leading lines after book line)
  const rest = lines.slice(1).join('\n').trim();

  let highlight = '';
  let annotation = '';

  if (rest.includes('💬')) {
    const noteIdx = rest.indexOf('💬');
    highlight = rest.slice(0, noteIdx).trim();
    annotation = rest.slice(noteIdx + '💬'.length).trim();
  } else {
    // Pure bookmark — strip optional [章节] prefix
    highlight = rest.replace(/^\[.*?\]\n+/, '').trim();
  }

  return { annotation, highlight, bookLine };
}

// Parse twitter text into structured parts.
// Repost format: "自己评论\n 账号名 (@handle) 原文 — nitter_url"
// Pure repost:   "账号名 (@handle) 原文 — nitter_url"
// Original:      plain text, no (@handle) pattern
function parseTwitter(text: string): { comment: string; rtAuthor: string; rtHandle: string; rtText: string } | null {
  // Find the LAST occurrence of "账号名 (@handle)" to split comment from RT
  const rtPattern = /^([\s\S]*?)([^\n(]+?)\s+\(@([A-Za-z0-9_]{1,50})\)\s+([\s\S]+)$/;
  const m = text.match(rtPattern);
  if (!m) return null;

  const comment = m[1].trim();
  const rtAuthor = m[2].trim();
  const handle = m[3].trim();
  let rtText = m[4].trim().replace(/\s+—\s+https?:\/\/\S+$/, '').trim();

  if (!rtText || rtText.length < 3) return null;

  return { comment, rtAuthor, rtHandle: handle, rtText };
}
---

<Base title="碎的念 · 冯诺" description="冯诺的碎片记录 — 豆瓣 · X / Twitter">

<nav>
  <a class="nav-home" href="/">冯诺</a>
  <ul class="nav-links">
    <li><a href="/translations">译的书</a></li>
    <li><a href="/writing">写的文</a></li>
    <li><a href="/projects">编的程</a></li>
    <li><a href="/tweets" class="here">碎的念</a></li>
  </ul>
  <button class="theme-toggle" id="themeBtn" onclick="toggleTheme()" aria-label="切换主题">
    <svg id="iconSun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <circle cx="12" cy="12" r="4"/>
      <line x1="12" y1="2" x2="12" y2="4"/>
      <line x1="12" y1="20" x2="12" y2="22"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="2" y1="12" x2="4" y2="12"/>
      <line x1="20" y1="12" x2="22" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg id="iconMoon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</nav>

<main>
  <header class="page-header">
    <p class="page-eyebrow">Says · Fragments</p>
    <h1 class="page-title">碎的念</h1>
    <p class="page-count">{page.total} 条记录 &nbsp;·&nbsp; Page {page.currentPage} / {page.lastPage}</p>
  </header>

  <div class="filter-bar">
    <button class="filter-btn active" data-filter="all">全部</button>
    <button class="filter-btn" data-filter="twitter">X 推文</button>
    <button class="filter-btn" data-filter="douban">豆瓣广播</button>
    <button class="filter-btn" data-filter="weread">读书笔记</button>
  </div>

  <div class="feed">
    {page.data.map((item: any) => {
      const imgs = filterImages(item.images || []);
      const isWeread = item.platform === 'weread';
      const isTwitter = item.platform === 'twitter';
      const wr = isWeread ? parseWeread(item.text) : null;
      const tw = isTwitter ? parseTwitter(item.text) : null;
      return (
        <div class="entry" data-platform={item.platform}>
          <div class="entry-spine">
            <span class={`entry-dot dot-${item.platform}`}></span>
            <div class="entry-line"></div>
          </div>
          <div class="entry-body">
            <div class="entry-meta">
              <span class={`entry-platform${isWeread ? ' platform-weread' : isTwitter ? ' platform-twitter' : ''}`}>
                {item.platform === 'twitter' ? 'X' : isWeread ? '读书笔记' : '豆瓣广播'}
              </span>
              {!isWeread && (
                <a class="entry-source" href={item.url} target="_blank" rel="noopener">查看原文</a>
              )}
              <span class="entry-date">{formatDate(item.date)}</span>
            </div>
            {isWeread && wr ? (
              <div class="wr-body">
                {wr.annotation && <p class="wr-annotation">{wr.annotation}</p>}
                {wr.highlight && (
                  <blockquote class="wr-highlight">
                    <span class="wr-quote-mark open">「</span>{wr.highlight}<span class="wr-quote-mark close">」</span>
                  </blockquote>
                )}
                <p class="wr-bookline">{wr.bookLine}</p>
              </div>
            ) : isTwitter && tw ? (
              <div class="tw-body">
                {tw.comment && <p class="entry-text tw-comment">{tw.comment}</p>}
                <blockquote class="tw-rt">
                  <p class="tw-rt-author">
                    <span class="tw-rt-name">{tw.rtAuthor}</span>
                    <span class="tw-rt-handle">@{tw.rtHandle}</span>
                  </p>
                  <p class="tw-rt-text">{tw.rtText}</p>
                </blockquote>
              </div>
            ) : (
              <p class="entry-text">{item.text}</p>
            )}
            {imgs.length > 0 && (
              <div class="entry-imgs">
                {imgs.slice(0, 4).map((img: string) => (
                  <img src={proxyImg(img)} loading="lazy" alt="" />
                ))}
              </div>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <nav class="pagination" aria-label="分页">
    {page.url.prev ? (
      <a class="page-btn" href={page.url.prev}>← 上一页</a>
    ) : (
      <span class="page-btn disabled">← 上一页</span>
    )}
    <span class="page-info">{page.currentPage} / {page.lastPage}</span>
    {page.url.next ? (
      <a class="page-btn" href={page.url.next}>下一页 →</a>
    ) : (
      <span class="page-btn disabled">下一页 →</span>
    )}
  </nav>
</main>

<footer>
  <a class="foot-back" href="/">← 返回主页</a>
  <span class="foot-copy">© 2026 冯诺</span>
</footer>

</Base>

<style>
nav {
  position: sticky;
  top: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 52px;
  height: 56px;
  background: var(--nav-gradient);
  border-bottom: 1px solid var(--rule);
  transition: background .25s;
}
.nav-home {
  font-family: 'Noto Serif SC', serif;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: .02em;
  opacity: .7;
  transition: opacity .2s;
}
.nav-home:hover { opacity: 1; }
.nav-links {
  display: flex;
  gap: 28px;
  list-style: none;
}
.nav-links a {
  font-family: 'Noto Serif SC', serif;
  font-size: 10px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--dim);
  transition: color .2s;
}
.nav-links a:hover { color: var(--paper); }
.nav-links a.here { color: var(--gold); }
.theme-toggle {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--dim);
  display: flex;
  align-items: center;
  padding: 4px;
  transition: color .2s;
}
.theme-toggle:hover { color: var(--paper); }
.theme-toggle svg { width: 15px; height: 15px; }

main {
  max-width: 680px;
  margin: 0 auto;
  padding: 72px 24px 100px;
}

.page-header {
  margin-bottom: 56px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--rule);
}
.page-eyebrow {
  font-size: 10px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 300;
  margin-bottom: 16px;
}
.page-title {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(36px, 6vw, 56px);
  font-weight: 900;
  color: var(--paper);
  letter-spacing: .02em;
  margin-bottom: 12px;
}
.page-count {
  font-size: 10px;
  letter-spacing: .16em;
  color: var(--muted);
  font-weight: 300;
}

.feed {
  display: flex;
  flex-direction: column;
}

.filter-bar {
  display: flex;
  gap: 8px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}
.filter-btn {
  font-family: 'Cormorant SC', serif;
  font-size: 10px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--muted);
  background: none;
  border: 1px solid var(--rule);
  border-radius: 2px;
  padding: 5px 12px;
  cursor: pointer;
  transition: color .15s, border-color .15s, background .15s;
}
.filter-btn:hover {
  color: var(--dim);
  border-color: var(--dim);
}
.filter-btn.active {
  color: var(--gold);
  border-color: var(--gold);
  background: color-mix(in srgb, var(--gold) 6%, transparent);
}

.entry {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 0 16px;
  padding-bottom: 32px;
}
.entry:last-child { padding-bottom: 0; }

.entry-spine {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.entry-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4px;
}
.dot-twitter { background: var(--paper); }
.dot-douban  { background: #07a761; }
.dot-weread  { background: #1677ff; }
.entry-line {
  width: 1px;
  flex: 1;
  background: var(--rule);
  margin-top: 8px;
  min-height: 16px;
}
.entry:last-child .entry-line { display: none; }

.entry-body {
  padding-top: 1px;
  transition: transform .2s ease, box-shadow .2s ease;
  border-radius: 4px;
}
.entry:hover .entry-body {
  transform: translateY(-3px);
  box-shadow: 0 6px 20px color-mix(in srgb, var(--paper) 8%, transparent);
}
.entry-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}
.entry-platform {
  font-family: 'Cormorant SC', serif;
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 400;
}
.entry-source {
  font-family: 'Cormorant SC', serif;
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 400;
  transition: opacity .15s;
}
.entry-source:hover { opacity: .7; }
.platform-weread { color: #1677ff !important; }
.platform-twitter { color: #000 !important; }
[data-theme="dark"] .platform-twitter { color: #fff !important; }
.entry[data-platform="twitter"] .entry-source { color: #000; }
[data-theme="dark"] .entry[data-platform="twitter"] .entry-source { color: #fff; }
.entry-date {
  font-size: 9px;
  color: var(--muted);
  letter-spacing: .08em;
  font-weight: 300;
}
.entry-text {
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 2;
  color: var(--dim);
  white-space: pre-wrap;
  transition: color .15s;
}

/* ── WeRead structured layout ── */
.wr-body {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.wr-annotation {
  font-family: 'Noto Serif SC', serif;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.9;
  color: var(--dim);
  margin: 0;
}
.wr-highlight {
  margin: 0;
  padding: 4px 0 4px 28px;
  border: none;
  background: none;
  border-radius: 0;
  position: relative;
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 2;
  color: var(--dim);
}
.wr-highlight::before {
  content: '\201C';
  position: absolute;
  left: 0;
  top: -6px;
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: 48px;
  line-height: 1;
  color: #1677ff;
  opacity: .55;
  font-weight: 700;
}
.wr-quote-mark { display: none; }
.wr-bookline {
  margin: 0;
  font-family: 'Libre Baskerville', serif;
  font-size: 11px;
  letter-spacing: .06em;
  color: var(--muted);
  text-align: right;
}

.entry-imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 12px;
  margin-bottom: 4px;
}
.entry-imgs img {
  width: 100px; height: 100px;
  object-fit: cover;
  border-radius: 2px;
}

/* ── Twitter repost card ── */
.tw-body { display: flex; flex-direction: column; gap: 10px; }
.tw-comment {
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 2;
  color: var(--dim);
  margin: 0;
  white-space: pre-wrap;
}
.tw-rt {
  margin: 0;
  padding: 12px 14px;
  border: 1px solid var(--rule);
  border-radius: 4px;
  background: color-mix(in srgb, var(--paper) 3%, transparent);
}
.tw-rt-author {
  display: flex;
  align-items: baseline;
  gap: 6px;
  margin: 0 0 6px;
}
.tw-rt-name {
  font-family: 'Noto Serif SC', serif;
  font-size: 12px;
  font-weight: 500;
  color: var(--dim);
}
.tw-rt-handle {
  font-family: 'Libre Baskerville', serif;
  font-size: 10px;
  color: var(--muted);
  letter-spacing: .04em;
}
.tw-rt-text {
  font-family: 'Noto Serif SC', serif;
  font-size: 13px;
  font-weight: 300;
  line-height: 1.9;
  color: var(--dim);
  margin: 0;
  white-space: pre-wrap;
}

.pagination {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 32px; margin-top: 32px;
  border-top: 1px solid var(--rule);
}
.page-btn {
  font-family: 'Cormorant SC', serif;
  font-size: 12px; font-weight: 400; letter-spacing: .14em;
  color: var(--gold); text-decoration: none;
  transition: opacity .2s;
}
.page-btn:hover { opacity: .7; }
.page-btn.disabled { color: var(--muted); pointer-events: none; }
.page-info {
  font-family: 'Cormorant SC', serif;
  font-size: 11px; font-weight: 400; letter-spacing: .14em;
  color: var(--muted);
}

footer {
  border-top: 1px solid var(--rule);
  padding: 24px 52px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.foot-back {
  font-size: 11px;
  letter-spacing: .1em;
  color: var(--dim);
  transition: color .2s;
}
.foot-back:hover { color: var(--paper); }
.foot-copy {
  font-size: 9px;
  letter-spacing: .12em;
  color: var(--muted);
}

@media (max-width: 640px) {
  nav { padding: 0 20px; }
  main { padding: 48px 20px 80px; }
  footer { padding: 20px; }
}
</style>

<script is:inline>
function updateIcon(isDark) {
  document.getElementById('iconSun').style.display  = isDark ? 'block' : 'none';
  document.getElementById('iconMoon').style.display = isDark ? 'none'  : 'block';
}
function toggleTheme() {
  var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  var next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('site-theme', next);
  updateIcon(next === 'dark');
}
(function () {
  var saved = localStorage.getItem('site-theme') || 'light';
  updateIcon(saved === 'dark');
}());

// Filter
(function () {
  var btns = document.querySelectorAll('.filter-btn');
  var entries = document.querySelectorAll('.entry');
  btns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var filter = btn.getAttribute('data-filter');
      btns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      entries.forEach(function (entry) {
        var show = filter === 'all' || entry.getAttribute('data-platform') === filter;
        entry.style.display = show ? '' : 'none';
      });
    });
  });
}());
</script>
