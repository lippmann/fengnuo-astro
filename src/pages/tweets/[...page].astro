---
import Base from '../../layouts/Base.astro';
import feedData from '../../data/feed.json';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const feed = feedData as any[];
  return paginate(feed, { pageSize: 20 });
}

const { page } = Astro.props as any;

function formatDate(iso: string) {
  const [y, m, d] = iso.split('-');
  return `${y} · ${m} · ${d}`;
}

function filterImages(images: string[]) {
  return images.filter(img => !img.includes('new_menu') && !img.includes('/icon/'));
}

function proxyImg(url: string) {
  if (url.includes('doubanio.com')) {
    return `https://wsrv.nl/?url=${encodeURIComponent(url)}&w=200&h=200&fit=cover`;
  }
  return url;
}
---

<Base title="碎的念 · 冯诺" description="冯诺的碎片记录 — 豆瓣 · X / Twitter">

<nav>
  <a class="nav-home" href="/">冯诺</a>
  <ul class="nav-links">
    <li><a href="/translations">译的书</a></li>
    <li><a href="/writing">写的文</a></li>
    <li><a href="/projects">编的程</a></li>
    <li><a href="/tweets" class="here">碎的念</a></li>
  </ul>
  <button class="theme-toggle" id="themeBtn" onclick="toggleTheme()" aria-label="切换主题">
    <svg id="iconSun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <circle cx="12" cy="12" r="4"/>
      <line x1="12" y1="2" x2="12" y2="4"/>
      <line x1="12" y1="20" x2="12" y2="22"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="2" y1="12" x2="4" y2="12"/>
      <line x1="20" y1="12" x2="22" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg id="iconMoon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</nav>

<main>
  <header class="page-header">
    <p class="page-eyebrow">Says · Fragments</p>
    <h1 class="page-title">碎的念</h1>
    <p class="page-count">{page.total} 条记录 &nbsp;·&nbsp; Page {page.currentPage} / {page.lastPage}</p>
  </header>

  <div class="feed">
    {page.data.map((item: any) => {
      const imgs = filterImages(item.images || []);
      return (
        <div class="entry">
          <div class="entry-spine">
            <span class={`entry-dot dot-${item.platform}`}></span>
            <div class="entry-line"></div>
          </div>
          <div class="entry-body">
            <div class="entry-meta">
              <span class="entry-platform">{item.platform === 'twitter' ? 'X' : 'Douban'}</span>
              <a class="entry-source" href={item.url} target="_blank" rel="noopener">查看原文</a>
              <span class="entry-date">{formatDate(item.date)}</span>
            </div>
            <p class="entry-text">{item.text}</p>
            {imgs.length > 0 && (
              <div class="entry-imgs">
                {imgs.slice(0, 4).map((img: string) => (
                  <img src={proxyImg(img)} loading="lazy" alt="" />
                ))}
              </div>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <nav class="pagination" aria-label="分页">
    {page.url.prev ? (
      <a class="page-btn" href={page.url.prev}>← 上一页</a>
    ) : (
      <span class="page-btn disabled">← 上一页</span>
    )}
    <span class="page-info">{page.currentPage} / {page.lastPage}</span>
    {page.url.next ? (
      <a class="page-btn" href={page.url.next}>下一页 →</a>
    ) : (
      <span class="page-btn disabled">下一页 →</span>
    )}
  </nav>
</main>

<footer>
  <a class="foot-back" href="/">← 返回主页</a>
  <span class="foot-copy">© 2026 冯诺</span>
</footer>

</Base>

<style>
nav {
  position: sticky;
  top: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 52px;
  height: 56px;
  background: var(--nav-gradient);
  border-bottom: 1px solid var(--rule);
  transition: background .25s;
}
.nav-home {
  font-family: 'Noto Serif SC', serif;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: .02em;
  opacity: .7;
  transition: opacity .2s;
}
.nav-home:hover { opacity: 1; }
.nav-links {
  display: flex;
  gap: 28px;
  list-style: none;
}
.nav-links a {
  font-family: 'Noto Serif SC', serif;
  font-size: 10px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--dim);
  transition: color .2s;
}
.nav-links a:hover { color: var(--paper); }
.nav-links a.here { color: var(--gold); }
.theme-toggle {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--dim);
  display: flex;
  align-items: center;
  padding: 4px;
  transition: color .2s;
}
.theme-toggle:hover { color: var(--paper); }
.theme-toggle svg { width: 15px; height: 15px; }

main {
  max-width: 680px;
  margin: 0 auto;
  padding: 72px 24px 100px;
}

.page-header {
  margin-bottom: 56px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--rule);
}
.page-eyebrow {
  font-size: 10px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 300;
  margin-bottom: 16px;
}
.page-title {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(36px, 6vw, 56px);
  font-weight: 900;
  color: var(--paper);
  letter-spacing: .02em;
  margin-bottom: 12px;
}
.page-count {
  font-size: 10px;
  letter-spacing: .16em;
  color: var(--muted);
  font-weight: 300;
}

.feed {
  display: flex;
  flex-direction: column;
}

.entry {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 0 16px;
  padding-bottom: 32px;
  cursor: pointer;
}
.entry:last-child { padding-bottom: 0; }
.entry:hover .entry-text { color: var(--paper); }

.entry-spine {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.entry-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4px;
}
.dot-twitter { background: var(--paper); }
.dot-douban  { background: #07a761; }
.entry-line {
  width: 1px;
  flex: 1;
  background: var(--rule);
  margin-top: 8px;
  min-height: 16px;
}
.entry:last-child .entry-line { display: none; }

.entry-body { padding-top: 1px; }
.entry-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}
.entry-platform {
  font-family: 'Cormorant SC', serif;
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 400;
}
.entry-date {
  font-size: 9px;
  color: var(--muted);
  letter-spacing: .08em;
  font-weight: 300;
}
.entry-text {
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 2;
  color: var(--dim);
  white-space: pre-wrap;
  transition: color .15s;
}
.entry-imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 12px;
  margin-bottom: 4px;
}
.entry-imgs img {
  width: 100px; height: 100px;
  object-fit: cover;
  border-radius: 2px;
}

.pagination {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 32px; margin-top: 32px;
  border-top: 1px solid var(--rule);
}
.page-btn {
  font-family: 'Cormorant SC', serif;
  font-size: 12px; font-weight: 400; letter-spacing: .14em;
  color: var(--gold); text-decoration: none;
  transition: opacity .2s;
}
.page-btn:hover { opacity: .7; }
.page-btn.disabled { color: var(--muted); pointer-events: none; }
.page-info {
  font-family: 'Cormorant SC', serif;
  font-size: 11px; font-weight: 400; letter-spacing: .14em;
  color: var(--muted);
}

footer {
  border-top: 1px solid var(--rule);
  padding: 24px 52px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.foot-back {
  font-size: 11px;
  letter-spacing: .1em;
  color: var(--dim);
  transition: color .2s;
}
.foot-back:hover { color: var(--paper); }
.foot-copy {
  font-size: 9px;
  letter-spacing: .12em;
  color: var(--muted);
}

@media (max-width: 640px) {
  nav { padding: 0 20px; }
  main { padding: 48px 20px 80px; }
  footer { padding: 20px; }
}
</style>

<script is:inline>
function updateIcon(isDark) {
  document.getElementById('iconSun').style.display  = isDark ? 'block' : 'none';
  document.getElementById('iconMoon').style.display = isDark ? 'none'  : 'block';
}
function toggleTheme() {
  var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  var next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('site-theme', next);
  updateIcon(next === 'dark');
}
(function () {
  var saved = localStorage.getItem('site-theme') || 'light';
  updateIcon(saved === 'dark');
}());
</script>
